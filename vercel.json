{
  "version": 2,
  "functions": {
    "server/server.js": {
      "includeFiles": [
        "css/**",
        "js/**",
        "assets/**",
        "index.html",
        "admin.html"
      ]
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/server/server.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
} 